@model BookBarn.Models.BookSuggestionModel

<h1>Suggest a Book</h1>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All"></div>

    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>

    <div>
        <label asp-for="Author"></label>
        <input asp-for="Author" />
        <span asp-validation-for="Author"></span>
    </div>

    <div>
        <label asp-for="Rating"></label>
        <input asp-for="Rating" />
        <span asp-validation-for="Rating"></span>
    </div>

    <div>
        <label asp-for="Notes"></label>
        <textarea asp-for="Notes"></textarea>
        <span asp-validation-for="Notes"></span>
    </div>

    <button type="submit">Submit Suggestion</button>
</form>